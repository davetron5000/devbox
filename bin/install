#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${0}" )" > /dev/null 2>&1 && pwd )
LOCAL_DX_SCRIPTS_DIR=$(realpath "${SCRIPT_DIR}"/../dx-scripts)

. "${LOCAL_DX_SCRIPTS_DIR}/setupkit.sh.lib"

DX_RELATIVE_DIR=dx
COMPOSE_TEMPLATE=$(realpath "${SCRIPT_DIR}"/../templates/docker-compose.template.yml)
COMPOSE_ENV_TEMPLATE=$(realpath "${SCRIPT_DIR}"/../templates/docker-compose.template.env)
DOCKERFILE_TEMPLATE=$(realpath "${SCRIPT_DIR}"/../templates/Docker.template.dx)
GIT_EMAIL=$(git config --global user.email || 'your-git-email@example.com')
GIT_NAME=$(git config --global user.name || 'Your Git Name')

main() {
  PROJECT_ROOT=
  BASE_IMAGE=
  PROJECT_NAME=
  ORG=
  TAG=
  PORT=none

  parse_command_line "${@}"

  PROJECT_DX_DIR="${PROJECT_ROOT}"/"${DX_RELATIVE_DIR}"
  PROJECT_DOCKERFILE="${PROJECT_ROOT}"/Dockerfile.dx
  PROJECT_COMPOSE_FILE="${PROJECT_ROOT}"/docker-compose.dx.yml
  PROJECT_COMPOSE_ENV="${PROJECT_DX_DIR}"/docker-compose.env

  setup_project_dir_if_needed
  create_dockerfile         "${DOCKERFILE_TEMPLATE}" "${PROJECT_DOCKERFILE}" "${BASE_IMAGE}" "${GIT_EMAIL}" "${GIT_NAME}"
  create_docker_compose     "${PROJECT_COMPOSE_FILE}" "${COMPOSE_TEMPLATE}" "${PORT}"
  copy_dx_scripts           "${LOCAL_DX_SCRIPTS_DIR}" "${PROJECT_DX_DIR}"
  create_docker_compose_env "${COMPOSE_ENV_TEMPLATE}" "${PROJECT_COMPOSE_ENV}" "${PROJECT_NAME}" "${ORG}" "${TAG}"

}

setup_project_dir_if_needed() {
  local gitignore="$PROJECT_ROOT/.gitignore"
  if [ ! -d "${PROJECT_ROOT}" ]; then
    log "📁" "Creating project root at '${PROJECT_ROOT}'"
    mkdir -p "${PROJECT_ROOT}"
  else
    log "✅" "Project root already exists at '${PROJECT_ROOT}'"
  fi

  require_not_exist "${PROJECT_DX_DIR}"        "Devbox is already installed in ${PROJECT_ROOT}, since it has a dx/ directory"
  require_not_exist "${PROJECT_DOCKERFILE}"    "${PROJECT_DOCKERFILE} already exists. Something may be wrong. Aborting"
  require_not_exist "${PROJECT_COMPOSE_FILE}"  "${PROJECT_COMPOSE_FILE} already exists. Something may be wrong. Aborting"
  
  touch "$gitignore"
  if ! grep -qxF '/dx/customizations.local.bash' "$gitignore"; then
    echo '# per-developer Bash configuration'
    echo '/dx/customizations.local.bash' >> "$gitignore"
  fi
  if ! grep -qxF '/dx/credentials' "$gitignore"; then
    echo '# per-developer secrets/credentials'
    echo '/dx/credentials' >> "$gitignore"
  fi
  if ! grep -qxF '/dx/state' "$gitignore"; then
    echo '# per-developer CLI state that must persist across containers'
    echo '/dx/state' >> "$gitignore"
  fi


}

create_dockerfile() {

  local dockerfile_template="$1"
  local dockerfile="$2"
  local base_image_name="$3"
  local git_email="$4"
  local git_name="$5"

  log "🐳" "Making the Dockerfile ${dockerfile} with base image ${base_image_name}"
  sed "s^%%BASE_IMAGE%%^${base_image_name}^g" "${dockerfile_template}" | \
  sed "s^%%GIT_EMAIL%%^${git_email}^g"                                  | \
  sed "s^%%GIT_NAME%%^${git_name}^g"                                    > "${dockerfile}"
  log "✅" "${dockerfile} created"
}

create_docker_compose() {
  compose_file="$1"
  template="$2"
  port="$3"

  log "🐋" "Making ${compose_file}"

  cp "${template}" "${compose_file}"
  if [ "${port}" != "none" ]; then
    log "🔌" "Adding port ${port}"
    {
      echo
      echo "    ports:"
      echo "      - \"${port}:${port}\""
      echo
    } >> "${compose_file}"
  fi

  log "✅" "${compose_file} created"
}

create_docker_compose_env() {
  compose_env_template="$1"
  project_compose_env="$2"
  project_name="$3"
  org="$4"
  tag="$5"

  image_name="${org}/${project_name}:${tag}"

  log "🎚️" "Initializing ${project_compose_env}"
  sed "s^%%PROJECT_NAME%%^${project_name}^g" "${compose_env_template}" | sed "s^%%IMAGE%%^${image_name}^g" > "${project_compose_env}"
  log "✅" "${project_compose_env} is ready"
}

copy_dx_scripts() {
  dx_scripts="$1"
  project_dx_dir="$2"

  log "🗃️" "Copying dx scripts to ${project_dx_dir}"
  mkdir -p "${project_dx_dir}"
  cp -r "${dx_scripts}"/* "${project_dx_dir}"
  log "✅" "${project_dx_dir} is ready"
}

parse_command_line() {
  while getopts "hp:o:t:i:a:n:g:e:" opt "${@}"; do
    case ${opt} in
      h )
        usage "DETAILED"
        ;;
      a )
        PROJECT_ROOT="${OPTARG}"
        ;;
      e )
        GIT_EMAIL="${OPTARG}"
        ;;
      g )
        GIT_NAME="${OPTARG}"
        ;;
      i )
        BASE_IMAGE="${OPTARG}"
        ;;
      n )
        PROJECT_NAME="${OPTARG}"
        ;;
      o )
        ORG="${OPTARG}"
        ;;
      p )
        PORT="${OPTARG}"
        ;;
      t )
        TAG="${OPTARG}"
        ;;
      \? )
        usage "Unknown option: ${OPTARG}"
        ;;
      : )
        usage "Invalid option: ${OPTARG} requires an argument"
        ;;
    esac
  done

  shift $((OPTIND -1))

  if [ -z "${ORG}" ]; then
    usage "You must supply an org with -o"
  fi

  if [ -z "${PROJECT_ROOT}" ]; then
    usage "You must supply the path to your app's root"
  fi

  if [ -z "${BASE_IMAGE}" ]; then
    usage "You must supply the base image to use"
  fi

  if [ -z "${PROJECT_NAME}" ]; then
    PROJECT_NAME=$(basename "${PROJECT_ROOT}")
    log "🧐" "Assuming project name is '${PROJECT_NAME}' - use -p to this script if you want to do something else"
  fi
  if [ -z "${TAG}" ]; then
    TAG=${BASE_IMAGE//:/-}
    log "🧐" "Assuming tag is '${TAG}' - use -t to this script if you want to do something else"
  fi
}

usage() {
  error_message=$1
  if [ -n "${error_message}" ]; then
    if [ "${error_message}" != "DETAILED" ]; then
      echo "${error_message}"
      echo
    fi
  fi
  echo "usage: $0 -a path_to_app -o org_name -i base_image \\"
  echo "          [-e git_email] [-g git_name] \\"
  echo "          [-p port] [-n project_name] [-t tag]"
  if [ -n "${error_message}" ]; then
    if [ "${error_message}" = "DETAILED" ]; then
      echo
      echo "DESCRIPTION"
      echo
      echo "    Initializes your project with Devbox. This will create a Dockerfile and"
      echo "    a Docker Compose file to run your project and copy several scripts to"
      echo "    interact with your dev evironment. Your project will NOT have a dependency"
      echo "    on devbox - you will own the files and scripts after you run this command."
      echo
      echo "OPTIONS"
      echo
      echo "    -h - show this help"
      echo "    -a - path to your app - will be created if not present (required)"
      echo "    -e - git email for the Dockerfile's get setup. Defaults to git config --global user.email"
      echo "    -g - git name for the Dockerfile's get setup. Defaults to git config --global user.name"
      echo "    -i - base image to use for Dockerfile (required)"
      echo "    -n - the name of your project. Defaults to the name of the directory for path_to_app"
      echo "    -o - the name of your project's org on DockerHub or GitHub (required)"
      echo "    -p - the port on which your project runs. If omitted, no port will be exposed"
      echo "    -t - a tag to use for your development container.  Defaults to the base_image name"
      echo
      echo "EXAMPLES"
      echo
      echo "   # my-new-app uses Node"
      echo "   devbox/bin/install -a my-new-app -i node:26 -o cyberdyne"
      echo
      echo "   # my-new-app uses Debian and will run on port 8088"
      echo "   devbox/bin/install -a my-new-app -i bookworm -o cyberdyne -p 8088"
    fi
  fi
  exit 1
}


main "${@}"

